{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "App Competition Monthly Deep Dive Snapshot",
  "type": "object",
  "required": [
    "metadata",
    "delivery_outputs",
    "report_rendering",
    "summary_cards",
    "market_snapshot",
    "release_analysis",
    "material_analysis",
    "keyword_analysis",
    "limitations"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "project_name",
        "report_slug",
        "report_type",
        "delivery_channel",
        "summary_doc_mode",
        "detail_doc_mode",
        "preserve_existing_content",
        "market_scope",
        "comparison_window",
        "latest_collection_at"
      ],
      "properties": {
        "project_name": { "type": "string" },
        "report_slug": { "type": "string" },
        "report_type": {
          "type": "string",
          "enum": ["baseline", "pulse", "monthly-deep-dive"]
        },
        "delivery_channel": { "type": "string" },
        "summary_doc_mode": { "type": "string" },
        "detail_doc_mode": { "type": "string" },
        "preserve_existing_content": { "type": "boolean" },
        "market_scope": {
          "type": "object",
          "required": [
            "target_app",
            "platforms",
            "primary_market",
            "secondary_markets",
            "target_keywords"
          ],
          "properties": {
            "target_app": { "type": "string" },
            "target_app_store_url": { "type": "string" },
            "platforms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "primary_market": { "type": "string" },
            "secondary_markets": {
              "type": "array",
              "items": { "type": "string" }
            },
            "target_keywords": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "primary_market": { "type": "string" },
        "secondary_markets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "comparison_window": { "type": "string" },
        "latest_collection_at": { "type": "string" },
        "report_path": { "type": "string" },
        "evidence_path": { "type": "string" }
      }
    },
    "delivery_outputs": {
      "type": "object",
      "required": ["summary_doc", "detail_doc"],
      "properties": {
        "summary_doc": {
          "type": "object",
          "required": ["doc_id", "doc_url", "title"],
          "properties": {
            "doc_id": { "type": "string" },
            "doc_url": { "type": "string" },
            "title": { "type": "string" }
          }
        },
        "detail_doc": {
          "type": "object",
          "required": ["doc_id", "doc_url", "title"],
          "properties": {
            "doc_id": { "type": "string" },
            "doc_url": { "type": "string" },
            "title": { "type": "string" }
          }
        }
      }
    },
    "report_rendering": {
      "type": "object",
      "required": [
        "primary_audience",
        "name_first",
        "body_uses_app_id",
        "body_uses_app_links",
        "main_sections"
      ],
      "properties": {
        "primary_audience": { "type": "string" },
        "name_first": { "type": "boolean" },
        "body_uses_app_id": { "type": "boolean" },
        "body_uses_app_links": { "type": "boolean" },
        "main_sections": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "summary_cards": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["question", "answer", "action"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    },
    "market_snapshot": {
      "type": "object",
      "required": ["summary", "comparison_matrix"],
      "properties": {
        "summary": {
          "type": "object",
          "required": ["state", "key_change_chain"],
          "properties": {
            "state": { "type": "string" },
            "key_change_chain": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "comparison_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["app_name", "app_id", "app_store_url", "role"],
            "properties": {
              "app_name": { "type": "string" },
              "app_id": { "type": "string" },
              "app_store_url": { "type": "string" },
              "role": { "type": "string" },
              "released_within_30d": { "type": ["boolean", "null"] },
              "top3_state": { "type": ["string", "null"] },
              "keyword_alert": { "type": ["string", "null"] },
              "why_it_matters": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "release_analysis": {
      "type": "object",
      "required": ["apps"],
      "properties": {
        "apps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "app_name",
              "app_id",
              "app_store_url",
              "current_version",
              "updated_at",
              "within_30d",
              "whats_new_raw",
              "whats_new_summary",
              "release_theme",
              "user_visible_change"
            ],
            "properties": {
              "app_name": { "type": "string" },
              "app_id": { "type": "string" },
              "app_store_url": { "type": "string" },
              "current_version": { "type": ["string", "null"] },
              "updated_at": { "type": ["string", "null"] },
              "within_30d": { "type": "boolean" },
              "whats_new_raw": { "type": ["string", "null"] },
              "whats_new_summary": { "type": ["string", "null"] },
              "release_theme": { "type": ["string", "null"] },
              "user_visible_change": {
                "type": "string",
                "enum": ["none", "low", "medium", "high"]
              }
            }
          }
        }
      }
    },
    "material_analysis": {
      "type": "object",
      "required": ["apps", "changes"],
      "properties": {
        "apps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "app_name",
              "app_id",
              "app_store_url",
              "top3",
              "screenshot_collection_status",
              "screenshot_sources",
              "device_coverage",
              "webpage_screenshot_evidence",
              "web_fallback_used"
            ],
            "properties": {
              "app_name": { "type": "string" },
              "app_id": { "type": "string" },
              "app_store_url": { "type": "string" },
              "screenshot_collection_status": { "type": "string" },
              "screenshot_sources": {
                "type": "array",
                "items": { "type": "string" }
              },
              "device_coverage": { "type": "string" },
              "webpage_screenshot_evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "web_fallback_used": { "type": "boolean" },
              "top3": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["position", "semantic_summary", "inferred"],
                  "properties": {
                    "position": { "type": "integer" },
                    "semantic_summary": { "type": "string" },
                    "inferred": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "app_name",
              "app_id",
              "app_store_url",
              "changed",
              "after_theme",
              "message_shift",
              "likely_reason",
              "change_chain",
              "screenshot_collection_status",
              "screenshot_sources",
              "device_coverage",
              "webpage_screenshot_evidence",
              "web_fallback_used",
              "inferred"
            ],
            "properties": {
              "app_name": { "type": "string" },
              "app_id": { "type": "string" },
              "app_store_url": { "type": "string" },
              "changed": { "type": ["boolean", "null"] },
              "before_theme": { "type": ["string", "null"] },
              "after_theme": { "type": ["string", "null"] },
              "message_shift": { "type": ["string", "null"] },
              "likely_reason": { "type": ["string", "null"] },
              "change_chain": {
                "type": "array",
                "items": { "type": "string" }
              },
              "screenshot_collection_status": { "type": "string" },
              "screenshot_sources": {
                "type": "array",
                "items": { "type": "string" }
              },
              "device_coverage": { "type": "string" },
              "webpage_screenshot_evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "web_fallback_used": { "type": "boolean" },
              "inferred": { "type": "boolean" }
            }
          }
        }
      }
    },
    "keyword_analysis": {
      "type": "object",
      "required": ["rank_tracking", "alerts"],
      "properties": {
        "rank_tracking": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "keyword",
              "target_rank",
              "previous_rank",
              "delta",
              "leader_app_name",
              "leader_rank",
              "leader_app_store_url",
              "collected_at",
              "target_keyword_source",
              "target_keyword_last_verified_at"
            ],
            "properties": {
              "keyword": { "type": "string" },
              "target_rank": { "type": ["integer", "null"] },
              "previous_rank": { "type": ["integer", "null", "string"] },
              "delta": { "type": ["integer", "null", "string"] },
              "leader_app_name": { "type": "string" },
              "leader_rank": { "type": ["integer", "null"] },
              "leader_app_store_url": { "type": "string" },
              "collected_at": { "type": "string" },
              "target_keyword_source": { "type": "string" },
              "target_keyword_last_verified_at": { "type": "string" },
              "leader_app_id": { "type": "string" },
              "traffic_score": { "type": ["number", "null"] },
              "difficulty_score": { "type": ["number", "null"] },
              "change_chain": {
                "type": "array",
                "items": { "type": "string" }
              },
              "alert_type": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "alerts": {
          "type": "object",
          "required": [
            "at_risk_target_keywords",
            "recoverable_target_keywords"
          ],
          "properties": {
            "at_risk_target_keywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "recoverable_target_keywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
